# ── DATABASE ──────────────────────────────────────────────────
DB_USERNAME=dsr_user
DB_PASSWORD=change_me_strong_password

# ── JWT ───────────────────────────────────────────────────────
# IMPORTANT: Change this to a random 256-bit string before production.
# Generate with: openssl rand -base64 32
JWT_SECRET=your-256-bit-secret-here-change-this-before-deploying
JWT_EXPIRY_MS=86400000

# ── GROQ AI ───────────────────────────────────────────────────
# Free tier at https://console.groq.com — no credit card required
GROQ_API_KEY=gsk_your_key_here

# ── EMAIL NOTIFICATIONS ───────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
# Use App Password (not your Gmail password): myaccount.google.com/apppasswords
MAIL_PASSWORD=xxxx xxxx xxxx xxxx
